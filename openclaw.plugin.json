{
  "id": "execution-gate",
  "name": "OpenClaw 执行门",
  "description": "用途：为 OpenClaw 工具调用提供确认、风险判断、结构化 MCP 管理和事务执行保护。",
  "version": "0.2.0",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "trustedToolPolicies": [
      "execution-gate"
    ],
    "tools": [
      "mcp_manage"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "dbPath": {
        "type": "string",
        "default": "~/.openclaw/state/execution-gate.sqlite"
      },
      "operationTtlMs": {
        "type": "integer",
        "minimum": 1000,
        "default": 900000
      },
      "executionTimeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "default": 120000
      },
      "runtimePolicyMode": {
        "type": "string",
        "enum": ["STRICT", "PERSONAL_SINGLE_USER"],
        "default": "STRICT"
      },
      "agentIds": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "benefits": { "type": "string", "default": "benefits-orchestrator" },
          "rem": { "type": "string", "default": "memory-agent" },
          "commercePrimary": { "type": "string", "default": "commerce-agent" },
          "commerceSecondary": { "type": "string", "default": "commerce-agent" }
        }
      },
      "mockOnly": {
        "type": "boolean",
        "default": false
      }
    }
  }
}
